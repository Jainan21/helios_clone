generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  id Int @id @default(autoincrement())
  firstName String
  lastName String
  email String @unique
  phone String 
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
}

model Jewelry{
  id Int @id @default(autoincrement())
  name String
  price Int
  description String
  material String @default("Bạc S925")
  stone String? 
  status JewelryStatus @default(ACTIVE)
  medias Media[]
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Media{
  id Int @id @default(autoincrement())
  url String
  type MediaType
  isThumbnail Boolean @default(false)
  sortOrder Int @default(0)

  jewelryId Int
  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([jewelryId])
}

enum MediaType{
  IMAGE
  VIDEO
}

enum JewelryStatus{
  ACTIVE
  SOLD_OUT
  NEW_IN
  PRE_ORDER
  HIDDEN
}