// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  phone     String
  password  String
  role      UserRole @default(USER)
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Jewelry {
  id          Int           @id @default(autoincrement())
  name        String
  price       Int
  description String
  material    String        @default("Bạc S925")
  stone       String?
  status      JewelryStatus @default(ACTIVE)
  type        JewelryType   @default(SILVER_RING)
  medias      Media[]
  cartItems   CartItem[]

  collectionId Int?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([collectionId])
}

model CartItem {
  id        Int     @id @default(autoincrement())
  quantity  Int     @default(1)

  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  jewelryId Int
  jewelry   Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jewelryId])
  @@index([userId])
  @@index([jewelryId])
}

model Media {
  id          Int       @id @default(autoincrement())
  url         String
  type        MediaType
  isThumbnail Boolean   @default(false)
  sortOrder   Int       @default(0)

  jewelryId Int?
  jewelry   Jewelry? @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  collectionId Int?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([jewelryId])
  @@index([collectionId])
}

model Collection {
  id          Int    @id @default(autoincrement())
  name        String
  description String

  medias  Media[]
  jewelry Jewelry[]

  createdAt DateTime @default(now())
}

enum MediaType {
  IMAGE
  VIDEO
}

enum JewelryStatus {
  ACTIVE
  SOLD_OUT
  NEW_IN
  PRE_ORDER
  HIDDEN
}

enum JewelryType {
  SILVER_RING
  SILVER_BRACELET
  SILVER_NECKLACE
  SILVER_PENDANT
  SILVER_CHARM
  SILVER_EARRINGS
  GOLD_JEWELRY
  GLASSES
  LEATHER_CRAFT
  OTHER_ACCESSORY
}

enum UserRole {
  USER
  ADMIN
}
